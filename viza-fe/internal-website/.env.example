NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_AGENT_BACKEND_URL=
NEXT_PUBLIC_FRANCE_SUBMISSION_MODE=dry_run
NEXT_PUBLIC_FRANCE_LIVE_SUBMISSION_ENABLED=false
NEXT_PUBLIC_DS160_SUBMISSION_MODE=dry_run
NEXT_PUBLIC_DS160_LIVE_ASSISTED_ENABLED=false
# Local submission-service health URL used by Vietnam one-time official-fee card sessions.
# Do not put PAN/CVV in env; users enter card details in the confirmation tab per payment.
SUBMISSION_SERVICE_LOCAL_URL=http://127.0.0.1:18080
TRAVEL_BACKEND_URL=http://127.0.0.1:8000
TRAVEL_GOOGLE_FALLBACK_ENABLED=true
GOOGLE_PLACES_API_ENABLED=true
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
GOOGLE_MAPS_API_KEY=
# Public origin of THIS portal app. Magic-link sign-in redirects
# (provisionAccountAndMagicLink) are built from this — set it to the
# portal host in every env (prod: https://app.viza.com), not the
# marketing host.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
# Optional override for the transactional From address (default
# "VIZA <welcome@haggstorm.com>"). Set to a Resend-verified domain,
# e.g. "VIZA <welcome@viza.com>".
NOTIFY_FROM_EMAIL=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
AIRWALLEX_ENV=demo
AIRWALLEX_BASE_URL=https://api-demo.airwallex.com
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
AIRWALLEX_LOGIN_AS=
AIRWALLEX_WEBHOOK_SECRET=
APP_BASE_URL=http://localhost:3000
TRANSLATION_PROVIDER=google
GOOGLE_TRANSLATE_API_VERSION=v2
GOOGLE_TRANSLATE_API_KEY=
TRANSLATION_MAX_CHARS_PER_REQUEST=5000
