NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_AGENT_BACKEND_URL=
NEXT_PUBLIC_FRANCE_SUBMISSION_MODE=dry_run
NEXT_PUBLIC_FRANCE_LIVE_SUBMISSION_ENABLED=false
NEXT_PUBLIC_DS160_SUBMISSION_MODE=dry_run
NEXT_PUBLIC_DS160_LIVE_ASSISTED_ENABLED=false
# Local submission-service health URL used by Vietnam one-time official-fee card sessions.
# Do not put PAN/CVV in env; users enter card details in the confirmation tab per payment.
SUBMISSION_SERVICE_LOCAL_URL=http://127.0.0.1:18080
TRAVEL_BACKEND_URL=http://127.0.0.1:8000
TRAVEL_GOOGLE_FALLBACK_ENABLED=true
GOOGLE_PLACES_API_ENABLED=true
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
GOOGLE_MAPS_API_KEY=
OPENAI_API_KEY=
OPENAI_FIELD_GUIDANCE_MODEL=gpt-5.5
PASSPORT_OCR_OPENAI_API_KEY=
FACE_MATCH_PROVIDER=openai_vision
FACE_MATCH_OPENAI_API_KEY=
FACE_MATCH_OPENAI_MODEL=gpt-4.1-mini
VN_FACE_MATCH_MIN_SCORE=0.7
# Public origin of THIS portal app. Magic-link sign-in redirects
# (provisionAccountAndMagicLink) are built from this — set it to the
# portal host in every env (prod: https://app.viza.it.com), not the
# marketing host.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
# Optional override for the transactional From address (default
# "VIZA <welcome@viza.it.com>"). Set to a Resend-verified domain,
# e.g. "VIZA <welcome@viza.it.com>".
NOTIFY_FROM_EMAIL=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
AIRWALLEX_ENV=demo
AIRWALLEX_BASE_URL=https://api-demo.airwallex.com
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
AIRWALLEX_LOGIN_AS=
AIRWALLEX_WEBHOOK_SECRET=
APP_BASE_URL=http://localhost:3000
TRANSLATION_PROVIDER=google
GOOGLE_TRANSLATE_API_VERSION=v2
GOOGLE_TRANSLATE_API_KEY=
TRANSLATION_MAX_CHARS_PER_REQUEST=5000

# Contact-form intake (app/api/contact) — enquiries are emailed here.
# Falls back to NOTIFY_FROM_EMAIL when unset.
CONTACT_INBOX_EMAIL=

# --- PhotonPay (收单 / checkout gateway; replaces Stripe in card-checkout when enabled) ---
# When PHOTONPAY_ENABLED=true, app/actions/card-checkout.ts mints a PhotonPay
# hosted cashier session instead of Stripe. NOTE: PhotonPay allowlists caller
# IPs, and Vercel has no static egress IP — in production this outbound call
# must run from the Render backend, not the Vercel function. Local/UAT dev runs
# from your whitelisted machine.
PHOTONPAY_ENABLED=false
PHOTONPAY_BASE_URL=https://x-api.photonpay.com   # UAT: https://x-api1.uat.photontech.cc
PHOTONPAY_APP_ID=
PHOTONPAY_APP_SECRET=
# Merchant RSA private key (PKCS#8). Inline PEM (\n-escaped) for prod, or a file
# path for local dev. Upload the PUBLIC half in PhotonPay 商户后台 → 开发者.
PHOTONPAY_PRIVATE_KEY=
PHOTONPAY_PRIVATE_KEY_PATH=
# PhotonPay platform public key (开发者 → API Key → PhotonPay公钥) — verifies webhooks.
PHOTONPAY_PLATFORM_PUBLIC_KEY=
PHOTONPAY_PLATFORM_PUBLIC_KEY_PATH=
# Store id from 收单 → 站点管理 → 详情 (UAT active test site: 20260703922412081001).
PHOTONPAY_SITE_ID=
# Public URL PhotonPay POSTs results to. Defaults to
# NEXT_PUBLIC_SITE_URL + /api/webhooks/photonpay; override for tunnels (ngrok) in dev.
PHOTONPAY_NOTIFY_URL=
