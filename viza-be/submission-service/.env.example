# viza-be/submission-service — environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Supabase (postgres + storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (failure alerts)
RESEND_API_KEY=re_your_resend_api_key

# 2captcha — solves the CEAC start-page image CAPTCHA (US-021–US-026).
# Get a key at https://2captcha.com/enterpage. Credit-based billing.
TWOCAPTCHA_API_KEY=your-2captcha-api-key

# Submission mode defaults
VIZA_SUBMISSION_DRY_RUN=1
SUBMISSION_RESULT_SECRET_KEY=replace-with-at-least-16-random-chars

# France / Schengen live-assisted mode. Keep dry-run as the default unless you
# are intentionally running a visible, applicant-controlled France-Visas assist.
FRANCE_SUBMISSION_MODE=dry_run
FRANCE_LIVE_SUBMISSION_ENABLED=false
FRANCE_LIVE_ASSISTED_ONLY=true
FRANCE_REQUIRE_FINAL_USER_CONFIRMATION=true
FRANCE_REQUIRE_OFFICIAL_REVIEW_DIFF_PASS=true
FRANCE_PLAYWRIGHT_HEADLESS=false
FRANCE_CAPTURE_TRACE=true
FRANCE_CAPTURE_SCREENSHOT=true
FRANCE_LIVE_MAX_DURATION_SECONDS=1800
FRANCE_OFFICIAL_BASE_URL=https://application-form.france-visas.gouv.fr/
FRANCE_PAYMENT_LIVE_ENABLED=false
FRANCE_APPOINTMENT_LIVE_ENABLED=false
# Optional France-Visas account registration. This uses a VIZA catch-all alias
# (`appl-*.haggstorm.com`) and 2captcha only for the registration image CAPTCHA.
# Login risk checks, Cloudflare/anti-bot gates, final validation, payment, and
# appointment booking remain manual.
FRANCE_ACCOUNT_REGISTRATION_ENABLED=false
FRANCE_REGISTRATION_2CAPTCHA_ENABLED=false
FRANCE_REGISTRATION_MAX_CAPTCHA_ATTEMPTS=3
FRANCE_REGISTRATION_EMAIL_TIMEOUT_MS=180000

# U.S. B1/B2 appointment / China USVisaScheduling runner. Keep disabled until
# a live smoke has a valid official session/account context and operator
# approval for the test account.
US_APPOINTMENT_ASSISTED_LIVE_ENABLED=false
US_APPOINTMENT_PROVIDER_ALLOWLIST=usvisascheduling
US_APPOINTMENT_SUPPORTED_COUNTRIES=CN
US_APPOINTMENT_RUNNER_BATCH_SIZE=3
US_APPOINTMENT_SLOT_CHECK_COOLDOWN_MS=600000
US_APPOINTMENT_BASE_URL=https://www.usvisascheduling.com/
US_APPOINTMENT_PLAYWRIGHT_ENABLED=false
US_APPOINTMENT_PLAYWRIGHT_HEADLESS=false
US_APPOINTMENT_CAPTCHA_SOLVING_ENABLED=false
US_APPOINTMENT_CAPTCHA_MAX_ATTEMPTS=2

# IMAP — shared inbox used by per-country runners to fetch verification
# / OTP emails from visa portals. Use a Gmail App Password (16-char,
# scoped, IMAP-only) — generate at https://myaccount.google.com/apppasswords.
# Never use the account's main password.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=your-throwaway@gmail.com
IMAP_PASSWORD=your-16-char-app-password

# Shared HMAC for signed runner results (must match agent-backend)
SUBMISSION_RESULT_SECRET_KEY=your-submission-result-hmac-key

# Ops alerting
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook
RESEND_OPS_ALERT_TO=ops@your-domain.com

# Public site URL (for links in e-visa retrieval emails)
NEXT_PUBLIC_SITE_URL=https://app.your-domain.com

# --- Per-country portal URLs (override built-in defaults; optional) ---
ID_PORTAL_URL=
EG_PORTAL_URL=
IN_PORTAL_URL=
LK_PORTAL_URL=
KH_PORTAL_URL=
LA_PORTAL_URL=
ZA_PORTAL_URL=
MY_PORTAL_URL=
TH_PORTAL_URL=
AE_PORTAL_URL=
TR_PORTAL_URL=
CA_PORTAL_URL=
AU_PORTAL_URL=
IT_VFS_CN_PORTAL_URL=

# --- Vietnam official payment pilot ---
# Frontend-entered cards should use the localhost one-time card-session endpoint.
# Do not put real card data in tracked files. Fixed-card env values are a local
# fallback only and must be set in process env or a secret manager, never in Git.
VN_OFFICIAL_PAYMENT_AUTOPAY=false
VN_LOCAL_CARD_SESSION_ENABLED=false
VN_FIXED_CARD_ENABLED=false
VN_FIXED_CARD_PAN=
VN_FIXED_CARD_EXPIRY=
VN_FIXED_CARD_CVV=
VN_FIXED_CARD_HOLDER_NAME=
VN_OFFICIAL_PAYMENT_DRY_RUN_RECEIPT=false

# --- Recon / debug toggles (optional) ---
RECON_HEADFUL=false
DEBUG_RECON=false
VN_RECON_HEADFUL=false
CEAC_HEADLESS=true
CEAC_SKIP_TRANSLATION_GATE=false
