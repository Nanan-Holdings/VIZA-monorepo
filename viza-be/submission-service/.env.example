# viza-be/submission-service — environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Supabase (postgres + storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (failure alerts)
RESEND_API_KEY=re_your_resend_api_key

# 2captcha — solves the CEAC start-page image CAPTCHA (US-021–US-026).
# Get a key at https://2captcha.com/enterpage. Credit-based billing.
TWOCAPTCHA_API_KEY=your-2captcha-api-key

# Submission mode defaults
VIZA_SUBMISSION_DRY_RUN=1
SUBMISSION_RESULT_SECRET_KEY=replace-with-at-least-16-random-chars
# Local legacy submission_queue runner concurrency. The current single-runner
# maximum is 10; set to 1 to force old serial behavior for diagnostics.
SUBMISSION_SERVICE_MAX_CONCURRENCY=10
# Multi-runner submission_queue leases. Apply agent-backend migration 0105
# before horizontally scaling submission-service instances.
SUBMISSION_SERVICE_WORKER_ID=
SUBMISSION_SERVICE_QUEUE_LEASE_SECONDS=900
# Cloud worker topology: country workers set RUNNER_JOB_COUNTRY and disable
# legacy polling. Keep the defaults locally unless intentionally splitting it.
SUBMISSION_SERVICE_LEGACY_QUEUE_ENABLED=true
SUBMISSION_SERVICE_RUNNER_JOB_CONSUMER_ENABLED=true
RUNNER_JOB_COUNTRY=

# France / Schengen live-assisted mode. Keep dry-run as the default unless you
# are intentionally running a visible, applicant-controlled France-Visas assist.
FRANCE_SUBMISSION_MODE=dry_run
FRANCE_LIVE_SUBMISSION_ENABLED=false
FRANCE_LIVE_ASSISTED_ONLY=true
FRANCE_REQUIRE_FINAL_USER_CONFIRMATION=true
FRANCE_REQUIRE_OFFICIAL_REVIEW_DIFF_PASS=true
FRANCE_PLAYWRIGHT_HEADLESS=false
FRANCE_CAPTURE_TRACE=true
FRANCE_CAPTURE_SCREENSHOT=true
FRANCE_LIVE_MAX_DURATION_SECONDS=1800
FRANCE_OFFICIAL_BASE_URL=https://application-form.france-visas.gouv.fr/
FRANCE_PAYMENT_LIVE_ENABLED=false
FRANCE_APPOINTMENT_LIVE_ENABLED=false
# Optional France-Visas account registration. This uses a VIZA catch-all alias
# (`appl-*.haggstorm.com`) and 2captcha only for the registration image CAPTCHA.
# Login risk checks, Cloudflare/anti-bot gates, final validation, payment, and
# appointment booking remain manual.
FRANCE_ACCOUNT_REGISTRATION_ENABLED=false
FRANCE_REGISTRATION_2CAPTCHA_ENABLED=false
FRANCE_REGISTRATION_MAX_CAPTCHA_ATTEMPTS=3
FRANCE_REGISTRATION_EMAIL_TIMEOUT_MS=180000

# U.S. B1/B2 appointment / China USVisaScheduling runner. Keep disabled until
# a live smoke has a valid official session/account context and operator
# approval for the test account.
US_APPOINTMENT_ASSISTED_LIVE_ENABLED=false
US_APPOINTMENT_PROVIDER_ALLOWLIST=usvisascheduling
US_APPOINTMENT_SUPPORTED_COUNTRIES=CN
US_APPOINTMENT_RUNNER_BATCH_SIZE=3
US_APPOINTMENT_SLOT_CHECK_COOLDOWN_MS=600000
US_APPOINTMENT_BASE_URL=https://www.usvisascheduling.com/
US_APPOINTMENT_PLAYWRIGHT_ENABLED=false
US_APPOINTMENT_PLAYWRIGHT_HEADLESS=false
US_APPOINTMENT_PLAYWRIGHT_CHANNEL=chrome
# Optional: connect runner to a user-launched real Chrome with CDP.
# Start locally with: powershell -ExecutionPolicy Bypass -File scripts/start-us-appointment-user-chrome.ps1
US_APPOINTMENT_CDP_ENDPOINT=
# Optional: Bright Data Browser API endpoint. Use Browser API zone credentials,
# not a proxy/unlocker zone. Example:
# wss://<BROWSER_API_USER>:<BROWSER_API_PASSWORD>@brd.superproxy.io:9222
BRIGHTDATA_BROWSER_API_ENDPOINT=
BRIGHTDATA_BROWSER_WS=
SBR_WS_ENDPOINT=
US_APPOINTMENT_STORAGE_STATE_PATH=output/playwright/usvisascheduling-storage-state.json
US_APPOINTMENT_CAPTCHA_SOLVING_ENABLED=false
US_APPOINTMENT_CAPTCHA_MAX_ATTEMPTS=2

# Arrival-card official portal browser endpoints. Leave blank to use local
# Playwright Chromium. Set a country-specific endpoint when a government portal
# blocks the local runner network but works through an authorized Browser API
# zone.
MDAC_BROWSER_API_ENDPOINT=
# Fly production: store this as a protected GitHub environment secret. The
# deployment workflow copies it to Fly Secrets; never add it to a Fly TOML or
# commit a Browser API/CDP URL because it contains provider credentials.
MDAC_BRIGHTDATA_BROWSER_API_ENDPOINT=
TDAC_BROWSER_API_ENDPOINT=
PH_ETRAVEL_BROWSER_API_ENDPOINT=
# PH eTravel can be classified as a government site by generic Browser API
# zones. By default the runner ignores global Bright Data endpoints for PH and
# uses local Chrome/CDP or a PH-specific endpoint. Set this only after verifying
# the global endpoint is allowed for etravel.gov.ph.
PH_ETRAVEL_USE_GLOBAL_BROWSER_API=false
PH_ETRAVEL_CDP_ENDPOINT=
PH_ETRAVEL_ACCOUNT_EMAIL=
PH_ETRAVEL_ACCOUNT_PASSWORD=
PH_ETRAVEL_EMAIL_VERIFICATION_TIMEOUT_MS=180000
# MDAC official portal currently blocks headless Chromium from this workstation.
# Leave unset for the runner default: local visible Google Chrome.
MDAC_PLAYWRIGHT_CHANNEL=chrome
MDAC_PLAYWRIGHT_HEADLESS=false
# TDAC is Cloudflare protected. The runner prefers TDAC_BROWSER_API_ENDPOINT,
# BRIGHTDATA_BROWSER_WS, or BRIGHTDATA_BROWSER_API_ENDPOINT when configured.
# With TDAC_REQUIRE_BROWSER_API set to false, worker can fall back to local Chrome/CDP
# if a configured Browser API endpoint is unreachable.
TDAC_REQUIRE_BROWSER_API=
TDAC_PLAYWRIGHT_CHANNEL=chrome
TDAC_PLAYWRIGHT_HEADLESS=false
# Start local Chrome/CDP for PH with:
# npm run ph-etravel:chrome
PH_ETRAVEL_PLAYWRIGHT_CHANNEL=chrome
PH_ETRAVEL_PLAYWRIGHT_HEADLESS=false

# Taiwan NIA overseas-China entry permit. Keep disabled until an authorized
# controlled applicant session is ready; the runner will not send a code unless
# both this setting and its explicit sendVerificationCode option are true.
TW_ENTRY_PERMIT_EMAIL_VERIFICATION_ENABLED=false
TW_ENTRY_PERMIT_EMAIL_TIMEOUT_MS=180000
TW_ENTRY_PERMIT_CAPTCHA_TIMEOUT_MS=180000
TW_ENTRY_PERMIT_BROWSER_API_ENDPOINT=
TW_ENTRY_PERMIT_CDP_ENDPOINT=

# IMAP — shared inbox used by per-country runners to fetch verification
# / OTP emails from visa portals. Use a Gmail App Password (16-char,
# scoped, IMAP-only) — generate at https://myaccount.google.com/apppasswords.
# Never use the account's main password.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=your-throwaway@gmail.com
IMAP_PASSWORD=your-16-char-app-password

# Shared HMAC for signed runner results (must match agent-backend)
SUBMISSION_RESULT_SECRET_KEY=your-submission-result-hmac-key

# Ops alerting
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook
RESEND_OPS_ALERT_TO=ops@your-domain.com

# Public site URL (for links in e-visa retrieval emails)
NEXT_PUBLIC_SITE_URL=https://app.your-domain.com

# --- Per-country portal URLs (override built-in defaults; optional) ---
ID_PORTAL_URL=
EG_PORTAL_URL=
IN_PORTAL_URL=
LK_PORTAL_URL=
KH_PORTAL_URL=
LA_PORTAL_URL=
ZA_PORTAL_URL=
MY_PORTAL_URL=
TH_PORTAL_URL=
AE_PORTAL_URL=
TR_PORTAL_URL=
CA_PORTAL_URL=
AU_PORTAL_URL=
IT_VFS_CN_PORTAL_URL=

# --- Vietnam official payment pilot ---
# Frontend-entered cards should use the localhost one-time card-session endpoint.
# Do not put real card data in tracked files. Fixed-card env values are a local
# fallback only and must be set in process env or a secret manager, never in Git.
VN_OFFICIAL_PAYMENT_AUTOPAY=false
VN_LOCAL_CARD_SESSION_ENABLED=false
VN_FIXED_CARD_ENABLED=false
VN_FIXED_CARD_PAN=
VN_FIXED_CARD_EXPIRY=
VN_FIXED_CARD_CVV=
VN_FIXED_CARD_HOLDER_NAME=

# --- Indonesia official payment pilot ---
# Enables local-only POST /local/indonesia/card-session for one-time
# official-fee card handoff. Never store real PAN/CVV in this file.
ID_LOCAL_CARD_SESSION_ENABLED=false
VN_OFFICIAL_PAYMENT_DRY_RUN_RECEIPT=false
# Optional managed alias rotation domain list for Indonesia eVisa account creation.
# Comma/space/semicolon-separated and tried in order; default is haggstorm.com.
INDONESIA_MANAGED_ALIAS_DOMAINS=haggstorm.com
# Optional legacy single-domain override (kept for backward compatibility).
INDONESIA_MANAGED_ALIAS_DOMAIN=

# --- Airwallex virtual card issuing (HK entity, PAY-004) ---
# Mints a fresh single-use virtual card per applicant for runner_escrow_card
# countries, scoped to the exact government fee + a short active window. Keep
# disabled until Issuing is enabled on the account and a sandbox smoke passes.
# Do NOT put real keys in tracked files — set these in process env / secrets.
AIRWALLEX_ISSUING_ENABLED=false
AIRWALLEX_ISSUING_BASE_URL=https://api.airwallex.com   # api-demo.airwallex.com for sandbox
AIRWALLEX_ISSUING_CLIENT_ID=
AIRWALLEX_ISSUING_API_KEY=
AIRWALLEX_ISSUING_CARDHOLDER_ID=        # shared delegate cardholder, created once
AIRWALLEX_ISSUING_CREATED_BY=Nanan Holdings Ltd
AIRWALLEX_ISSUING_CARD_EXPIRY_MINUTES=120
AIRWALLEX_ISSUING_FX_BUFFER_PCT=0

# --- Recon / debug toggles (optional) ---
RECON_HEADFUL=false
DEBUG_RECON=false
VN_RECON_HEADFUL=false
CEAC_HEADLESS=true
CEAC_SKIP_TRANSLATION_GATE=false
# Browserbase cloud browser sessions (no project ID is required). Keep disabled
# until the account has proxy access and the target domain has passed a read-only smoke.
BROWSERBASE_API_KEY=
MDAC_BROWSERBASE_ENABLED=false
MDAC_BROWSERBASE_PROXIES=true
MDAC_BROWSERBASE_REGION=ap-southeast-1
MDAC_BROWSERBASE_COUNTRY=MY
