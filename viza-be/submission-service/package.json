{
  "name": "viza-submission-service",
  "version": "1.0.0",
  "description": "VIZA browser automation service - polls submission_queue and submits Indonesian e-visa applications via Playwright",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.spec.ts\"",
    "install-browsers": "playwright install chromium",
    "recon:uk": "ts-node src/uk/form-recon.ts",
    "seed:edward-creds": "ts-node scripts/seed-edward-test-credentials.ts",
    "seed:test-ds160-applicant": "ts-node scripts/seed-test-ds160-applicant.ts",
    "audit:ds160-parity": "ts-node scripts/audit-ds160-field-parity.ts",
    "imap:smoke": "ts-node scripts/imap-smoke.ts",
    "inbox:smoke": "ts-node scripts/inbox-smoke.ts",
    "recon:kh": "ts-node src/kh/form-recon.ts",
    "recon:la": "ts-node src/la/form-recon.ts",
    "recon:lk": "ts-node src/lk/form-recon.ts",
    "recon:za": "ts-node src/za/form-recon.ts",
    "recon:in": "ts-node src/in/form-recon.ts",
    "recon:parallel": "ts-node scripts/parallel-recon.ts",
    "promote:selectors": "ts-node scripts/promote-selectors.ts",
    "stress:run": "ts-node scripts/runner-stress.ts",
    "stress:digest": "ts-node scripts/runner-stress-digest.ts",
    "derive:question-sets": "ts-node scripts/derive-question-sets.ts",
    "queue:list-stuck": "ts-node scripts/queue/list-stuck-jobs.ts",
    "queue:requeue": "ts-node scripts/queue/requeue-jobs.ts",
    "queue:backfill": "ts-node scripts/queue/backfill-paid-orders.ts",
    "db:verify-queue": "ts-node scripts/db/verify-queue-schema.ts",
    "db:verify-inputs": "ts-node scripts/db/verify-runner-inputs.ts",
    "db:verify": "npm run db:verify-queue && npm run db:verify-inputs",
    "db:diff-migrations": "ts-node scripts/db/diff-migrations.ts",
    "launch:e2e-smoke": "ts-node scripts/launch/e2e-smoke.ts"
  },
  "dependencies": {
    "@playwright/test": "^1.41.0",
    "@supabase/supabase-js": "^2.39.0",
    "dotenv": "^16.3.1",
    "imapflow": "^1.3.3",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "resend": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "tsx": "^4.19.0"
  }
}
