{
  "name": "viza-submission-service",
  "version": "1.0.0",
  "description": "VIZA browser automation service - polls submission_queue and submits Indonesian e-visa applications via Playwright",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "node -r ts-node/register -r ./scripts/ts-node-js-resolver.cjs src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.spec.ts\"",
    "test:local-helpers": "node --test scripts/__tests__/start-local-official-helpers.test.mjs",
    "install-browsers": "playwright install chromium",
    "recon:uk": "ts-node src/uk/form-recon.ts",
    "seed:edward-creds": "ts-node scripts/seed-edward-test-credentials.ts",
    "seed:test-ds160-applicant": "ts-node scripts/seed-test-ds160-applicant.ts",
    "audit:ds160-parity": "ts-node scripts/audit-ds160-field-parity.ts",
    "imap:smoke": "ts-node scripts/imap-smoke.ts",
    "inbox:smoke": "ts-node scripts/inbox-smoke.ts",
    "au:smoke": "ts-node scripts/run-au-smoke.ts",
    "mdac:smoke": "tsx scripts/run-mdac-smoke.ts",
    "mdac:connectivity-smoke": "node dist/mdac/connectivity-smoke.js",
    "portal:connectivity-smoke": "node dist/portal-connectivity-smoke.js",
    "appointment:free-smoke": "tsx scripts/run-appointment-free-smoke.ts",
    "france-tls:registration-recon": "tsx scripts/run-france-tls-registration-recon.ts",
    "france-tls:readiness": "tsx scripts/check-france-tls-readiness.ts",
    "france-tls:register-account": "tsx scripts/run-france-tls-register-account.ts",
    "france-tls:appointment-flow": "tsx scripts/run-france-tls-appointment-flow.ts",
    "tw-entry-permit:smoke": "tsx scripts/run-tw-entry-permit-smoke.ts",
    "ph-etravel:smoke": "tsx scripts/run-ph-etravel-smoke.ts",
    "ph-etravel:chrome": "powershell -ExecutionPolicy Bypass -File scripts/start-ph-etravel-user-chrome.ps1",
    "us-appointment:register": "ts-node -r ./scripts/ts-node-js-resolver.cjs scripts/run-us-appointment-register.ts",
    "us-appointment:flow": "tsx scripts/run-us-appointment-flow.ts",
    "us-appointment:registration-recon": "tsx scripts/run-us-appointment-registration-recon.ts",
    "korea-eform:local": "tsx scripts/start-korea-eform-local.ts",
    "korea-eform:audit": "tsx scripts/audit-korea-eform-fill.ts",
    "korea-addresses:crawl": "tsx scripts/crawl-korea-addresses.ts",
    "france-tls:live-smoke": "tsx scripts/run-france-tls-live-smoke.ts",
    "france-tls:local-login-smoke": "tsx scripts/run-france-tls-local-login-smoke.ts",
    "tdac:smoke": "tsx scripts/run-tdac-smoke.ts",
    "vn:smoke": "ts-node scripts/run-vn-smoke.ts",
    "vn:card:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-vn-card-profile.ps1",
    "vn:autopay:dev": "powershell -ExecutionPolicy Bypass -File scripts/start-vn-autopay-dev.ps1",
    "local:official-helpers": "powershell -ExecutionPolicy Bypass -File scripts/start-local-official-helpers.ps1",
    "recon:kh": "ts-node src/kh/form-recon.ts",
    "recon:la": "ts-node src/la/form-recon.ts",
    "recon:lk": "ts-node src/lk/form-recon.ts",
    "recon:za": "ts-node src/za/form-recon.ts",
    "recon:in": "ts-node src/in/form-recon.ts",
    "recon:parallel": "ts-node scripts/parallel-recon.ts",
    "promote:selectors": "ts-node scripts/promote-selectors.ts",
    "stress:run": "ts-node scripts/runner-stress.ts",
    "stress:digest": "ts-node scripts/runner-stress-digest.ts",
    "derive:question-sets": "ts-node scripts/derive-question-sets.ts",
    "audit:country-submissions": "ts-node src/country-submissions/audit.ts",
    "test:country-submissions": "node --test -r ts-node/register src/country-submissions/__tests__/registry.spec.ts",
    "queue:list-stuck": "ts-node scripts/queue/list-stuck-jobs.ts",
    "queue:requeue": "ts-node scripts/queue/requeue-jobs.ts",
    "queue:backfill": "ts-node scripts/queue/backfill-paid-orders.ts",
    "db:verify-queue": "ts-node scripts/db/verify-queue-schema.ts",
    "db:verify-inputs": "ts-node scripts/db/verify-runner-inputs.ts",
    "db:verify": "npm run db:verify-queue && npm run db:verify-inputs",
    "db:diff-migrations": "ts-node scripts/db/diff-migrations.ts",
    "launch:e2e-smoke": "ts-node scripts/launch/e2e-smoke.ts"
  },
  "dependencies": {
    "@playwright/test": "^1.41.0",
    "@supabase/supabase-js": "^2.39.0",
    "dotenv": "^16.3.1",
    "imapflow": "^1.3.3",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "resend": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "tsx": "^4.19.0"
  }
}
