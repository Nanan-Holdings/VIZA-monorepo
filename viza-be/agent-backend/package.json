{
	"name": "@viza/agent-backend",
	"version": "1.0.0",
	"description": "VIZA Visa Assistant Agent - AI-powered assistant for visa application services",
	"main": "dist/index.js",
	"type": "module",
	"scripts": {
		"start": "node dist/index.js",
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"lint": "eslint .",
		"type-check": "tsc --noEmit",
		"prep": "npm run lint && npm run type-check",
		"test": "vitest run",
		"test:unit": "vitest run tests/unit",
		"test:integration": "vitest run tests/integration",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:db": "tsx src/db/migrate.ts",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:migrate": "tsx src/db/migrate.ts",
		"ingest:faqs": "tsx scripts/ingest-faqs.ts",
		"seed:ds160-form-fields": "tsx scripts/seed-ds160-form-fields.ts"
	},
	"keywords": [
		"visa",
		"visa-services",
		"ai-agent",
		"claude",
		"visa-assistant",
		"immigration",
		"supabase",
		"pgvector"
	],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@anthropic-ai/sdk": "^0.67.0",
		"@google-cloud/translate": "^9.3.0",
		"@google/generative-ai": "^0.24.0",
		"@supabase/supabase-js": "^2.74.0",
		"@types/pdf-parse": "^1.1.5",
		"agentevals": "^0.0.6",
		"axios": "^1.12.2",
		"cheerio": "^1.1.2",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.1",
		"cors": "^2.8.6",
		"date-fns": "^4.1.0",
		"dotenv": "^16.4.5",
		"drizzle-orm": "^0.30.10",
		"express": "^4.19.2",
		"fetch-blob": "^4.0.0",
		"json5": "^2.2.3",
		"langsmith": "^0.2.15",
		"node-fetch": "^2.7.0",
		"openai": "^6.32.0",
		"openevals": "^0.1.4",
		"pdf-parse": "^1.1.1",
		"pg": "^8.11.5",
		"socket.io": "^4.7.5",
		"web-streams-polyfill": "^4.2.0",
		"zod": "^3.25.76",
		"zod-to-json-schema": "^3.23.0"
	},
	"devDependencies": {
		"@types/cheerio": "^0.22.35",
		"@types/cors": "^2.8.19",
		"@types/express": "^4.17.21",
		"@types/node": "^20.12.12",
		"@types/node-fetch": "^2.6.13",
		"@types/pg": "^8.11.6",
		"@types/supertest": "^6.0.2",
		"@typescript-eslint/eslint-plugin": "^8.42.0",
		"@typescript-eslint/parser": "^8.42.0",
		"@vitest/coverage-v8": "^1.6.1",
		"drizzle-kit": "^0.21.1",
		"eslint": "^9.34.0",
		"socket.io-client": "^4.7.5",
		"supertest": "^7.0.0",
		"tsx": "^4.9.3",
		"typescript": "^5.4.5",
		"typescript-eslint": "^8.42.0",
		"vitest": "^1.6.0"
	}
}
