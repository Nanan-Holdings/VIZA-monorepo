# viza-be/agent-backend — environment variables
# Copy to `.env` and fill in real values. `.env` is gitignored.
# Canonical secret inventory: docs/security/secret-rotation-runbook.md

# --- Runtime ---
NODE_ENV=development
PORT=3002
APP_VERSION=0.0.0-dev
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001

# --- Supabase (service-role bypasses RLS — keep secret) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project.supabase.co:5432/postgres
# Client-side Supabase (also referenced by some shared code)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- LLM / AI providers ---
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
OPENAI_VALIDATION_MODEL=gpt-4o-mini
OPENAI_FIELD_GUIDANCE_MODEL=gpt-5.5
OPENAI_PASSPORT_SCAN_MODEL=gpt-4o
GOOGLE_AI_API_KEY=your-google-ai-api-key
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key
LANGSMITH_API_KEY=your-langsmith-api-key
FIELD_GUIDANCE_EVAL_DISABLE_RETRIEVAL=false

# --- Cross-service auth tokens (set identically on caller + callee) ---
AGENT_BACKEND_INTERNAL_TOKEN=your-internal-token
INTERNAL_AUTOMATION_TOKEN=your-automation-token
EXTERNAL_SUBMISSION_TOKEN=your-submission-token
SUBMISSION_RESULT_SECRET_KEY=your-submission-result-hmac-key
# Japan VFS Singapore cloud observer. Use the same private token in the
# submission-service Fly app; never expose it to the frontend.
JP_VFS_SG_SUBMISSION_SERVICE_URL=http://127.0.0.1:8080
JP_VFS_SG_INTERNAL_TOKEN=your-japan-vfs-internal-token

# --- Email / SMS / messaging ---
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=notifications@your-domain.com
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM=+10000000000
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# --- Observability / alerting ---
SENTRY_DSN=https://your-sentry-dsn
SENTRY_ENV=development
SENTRY_RELEASE=dev
VIZA_RUNNER_PD_KEY=your-pagerduty-routing-key
FEE_SCRAPER_SLACK_WEBHOOK=https://hooks.slack.com/services/your-webhook
ONCALL_RUNBOOK_URL=https://your-docs/oncall
# France TLScontact account preparation is opt-in. The URL should be the
# submission-service private Fly address; the token must match its Fly secret.
FRANCE_TLS_SUBMISSION_SERVICE_URL=
FRANCE_TLS_ACCOUNT_PREP_ENABLED=false
FRANCE_TLS_INTERNAL_TOKEN=
