# ============================================
# Monorepo .gitignore for VIZA
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Next.js
.next/
out/
build/
dist/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Testing
coverage/
.turbo/
test-results/
playwright-report/
blob-report/
playwright/*
.playwright-mcp/

# Production
*.log
*.log.*

# Debugging
.dev-logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================
# Secrets & environment variables (exhaustive)
# Patterns are recursive: they match in the root AND every nested
# workspace (viza-be/agent-backend, viza-be/submission-service,
# viza-be/email-worker, viza-be/travel-service,
# viza-fe/internal-website, viza-fe/marketing-website).
# Keep *.example templates tracked via the negations below.
# ============================================
.env
.env.*
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
# Service-account / cloud credential blobs
*service-account*.json
*serviceaccount*.json
*-credentials.json
gcp-*.json
firebase-adminsdk-*.json
# Keys & key material
*.key
*.p12
*.pfx
*.keystore
.agents/local-test-credentials.env
.agents/local-payment-card.env
# But always keep example/template files tracked
!.env.example
!.env*.example
!*.example.json

# Vercel
.vercel

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# macOS network shares
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Certificates
*.pem
*.crt
*.cer

# Claude - ignore local state but track project instructions
.claude/*
!.claude/CLAUDE.md
!.claude/lessons.md

# Cursor - ignore local state but track rules
.cursor/*
!.cursor/rules/

# Python
.venv/
venv/
__pycache__/
*.pyc

# Generated output files
knowledge-base/visa-news.json

# Submission service recon/diagnostic artifacts (HTML/PNG dumps)
viza-be/submission-service/diag-out/
viza-be/submission-service/e2e-out/
viza-be/submission-service/recon-out/
viza-be/submission-service/vn-recon-out/
viza-be/submission-service/vn-recon-out-minimal/
viza-be/submission-service/vn-recon-out-v2/
viza-be/submission-service/vn-recon-out-v3/
